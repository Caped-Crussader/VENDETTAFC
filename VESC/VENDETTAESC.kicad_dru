(version 1)
(rule "GND zone clearance to 50 Ohm nets"
  (constraint clearance (min 0.300mm))
  (condition "A.NetClass == '50Ohm' && B.Type == 'Zone'")
)

(rule "relaxed_clearance"
   (constraint clearance (min 0.1mm))
)

(rule "pad_clearance"
   (constraint clearance (min 0.1mm))
   (condition "A.Type == 'Pad' && B.Type == 'Pad'")
)

